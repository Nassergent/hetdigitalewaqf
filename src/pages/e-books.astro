---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import { fetchAllEbooks } from '../lib/sanity';

const allEbooks = await fetchAllEbooks();

// Split in beschikbaar en gepland
const beschikbaar = allEbooks.filter((e: any) => e.gepubliceerd);
const gepland = allEbooks.filter((e: any) => !e.gepubliceerd);
const totalDownloads = beschikbaar.reduce((sum: number, e: any) => sum + (e.downloadCount || 0), 0);
---

<Layout title="E-books — Ontdek de Islam Serie | Ummah.be Waqf" description="Gratis e-books over de islam: van introductie tot verdieping. De Ontdek de Islam serie — sadaqah jariyah door kennis.">

  <!-- HERO -->
  <section class="section" style="background: var(--color-capital);">
    <div class="container text-center max-w-[700px]">
      <span class="badge badge-sacred mb-4 fade-up">Ontdek de Islam Serie</span>
      <h1 class="text-white mb-4 fade-up delay-1">E-books</h1>
      <p class="text-white/80 text-lg fade-up delay-2">Gratis kennis als sadaqah jariyah — van introductie tot verdieping</p>
    </div>
  </section>

  <Breadcrumbs items={[{ label: 'Wat we doen', href: '/wat-we-doen' }, { label: 'E-books' }]} />

  <!-- INTRO -->
  <section class="section-sm">
    <div class="container-narrow">
      <div class="card card-static fade-up">
        <blockquote class="blockquote-gold pl-4 mb-4 font-heading italic text-lg">
          "Wanneer een mens sterft, stoppen al zijn daden behalve drie: een doorlopende liefdadigheid (sadaqah jariyah), kennis waar men profijt van heeft, en een rechtschapen kind dat voor hem bidt."
        </blockquote>
        <p class="text-sm text-text-light mb-4">— Sahih Muslim 1631</p>
        <p class="text-base text-text">
          Deze e-books zijn gratis. Geen email vereist. Geen voorwaarden. Kennis delen is onze eerste daad van sadaqah jariyah.
        </p>
      </div>
    </div>
  </section>

  <!-- BESCHIKBARE E-BOOKS -->
  <section class="section" style="background: white;">
    <div class="container max-w-[900px]">
      <h2 class="text-center mb-4 fade-up">Beschikbaar</h2>
      <p class="text-center text-text-light mb-10 fade-up delay-1">Gratis te downloaden — geen email vereist, geen voorwaarden.</p>

      {totalDownloads > 0 && (
        <div class="text-center mb-8 fade-up">
          <p class="text-sm font-semibold text-text-light">
            <span class="text-capital font-bold text-lg">{totalDownloads}</span> e-books gedownload
          </p>
        </div>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {beschikbaar.map((book: any, i: number) => (
          <div class="card card-capital fade-up" style={`animation-delay: ${i * 0.06}s;`}>
            <div class={`${book.omslagKleur} rounded-lg mb-4 flex items-center justify-center p-6`} style="min-height: 160px;">
              <div class="text-center">
                <p class="text-xs text-white/70 uppercase tracking-wider mb-1">Boek {i + 1}</p>
                <p class="font-heading font-bold text-lg text-white leading-tight">{book.titel}</p>
              </div>
            </div>
            <span class="badge badge-sacred mb-3">{book.categorie}</span>
            <h3 class="text-lg mb-2">{book.titel}</h3>
            <p class="text-sm text-text-light mb-4">{book.beschrijving}</p>
            <p class="text-xs text-text-light mb-4">{book.aantalPaginas}</p>
            {book.pdfUrl ? (
              <button class="btn btn-capital text-center w-full block" data-download-url={book.pdfUrl} data-ebook-id={book.titel}>Download PDF</button>
            ) : (
              <span class="btn text-center w-full block" style="background: var(--color-border); color: var(--color-text-light); cursor: default;">PDF wordt binnenkort toegevoegd</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GEPLANDE TITELS -->
  <section class="section">
    <div class="container max-w-[900px]">
      <h2 class="text-center mb-4 fade-up">Geplande titels in deze serie</h2>
      <p class="text-center text-text-light mb-10 fade-up delay-1">Deze boeken worden stap voor stap geschreven en gepubliceerd.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {gepland.map((book: any, i: number) => (
          <div class="card card-static fade-up" style={`animation-delay: ${i * 0.06}s;`}>
            <div class="flex items-start gap-3">
              <span class="step-number step-number-capital shrink-0" style="width: 36px; height: 36px; font-size: 14px; margin: 0;">{i + 3}</span>
              <div>
                <h3 class="text-base mb-1">{book.titel}</h3>
                <p class="text-xs text-text-light">{book.categorie}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CALL FOR SUGGESTIONS -->
  <section class="section-sm">
    <div class="container text-center max-w-[600px] fade-up">
      <h2 class="mb-4">Mis je een onderwerp?</h2>
      <p class="text-lg text-text-light mb-6">Laat het ons weten. We schrijven graag nieuwe e-books op basis van jullie vragen.</p>
      <a href="/contact" class="btn btn-outline">Stel een onderwerp voor</a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg" style="background: var(--color-capital-dark);">
    <div class="container text-center max-w-[700px]">
      <p class="display-quote text-white/90 mb-8 fade-up" style="font-style: italic;">
        Kennis delen is sadaqah jariyah
      </p>
      <p class="text-white/70 text-lg mb-10 fade-up delay-1">Steun ons werk en help ons meer kennis te verspreiden.</p>
      <div class="flex gap-4 justify-center flex-wrap fade-up delay-2">
        <a href="/de-bouwers" class="btn btn-gold">Word Bouwer</a>
        <a href="/wat-we-doen" class="btn btn-outline-white">Bekijk al onze projecten</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Download tracking
  document.querySelectorAll('[data-download-url]').forEach(btn => {
    btn.addEventListener('click', () => {
      const url = (btn as HTMLElement).dataset.downloadUrl;
      const id = (btn as HTMLElement).dataset.ebookId;
      window.open(url, '_blank');
      fetch('/api/track-download', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ebookId: id})
      }).catch(() => {});
    });
  });

  // Category filter removed — serie-structuur heeft geen filter nodig
</script>
